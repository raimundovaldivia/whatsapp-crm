# =============================================
# WhatsApp CRM - Variables de Entorno
# =============================================
# Copia este archivo como .env y completa los valores

# --- SERVER ---
PORT=3001
NODE_ENV=development

# --- WHATSAPP (Meta Business API) ---
# Obtenlos en: https://developers.facebook.com/apps/
WHATSAPP_TOKEN=tu_access_token_permanente
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=tu_business_account_id
WEBHOOK_VERIFY_TOKEN=un_token_secreto_que_tu_eliges_para_verificar_webhook

# --- ANTHROPIC (Claude) ---
# Obtenlo en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- SHOPIFY ---
# Obtenlos en: Tu tienda > Configuración > Apps > Desarrollar apps
SHOPIFY_STORE_URL=tu-tienda.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...

# --- FRONTEND URL (para CORS) ---
FRONTEND_URL=http://localhost:5173
